<FavoritesScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0

        canvas.before:
            Color:
                rgb: 0.15, 0.18, 0.22
            Rectangle:
                pos: self.pos
                size: self.size

        # Header
        BoxLayout:
            size_hint_y: None
            height: "56dp"
            padding: [15, 0]
            spacing: 15

            canvas.before:
                Color:
                    rgb: 0.12, 0.14, 0.18
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "My Favorites"
                font_size: "20sp"
                bold: True
                color: 1, 1, 1, 1
                size_hint_x: 1
                halign: "left"
                valign: "middle"
                text_size: self.size

            Button:
                text: "⚙"
                font_size: "20sp"
                size_hint_x: None
                width: "50dp"
                background_color: 0, 0, 0, 0
                on_release: root.manager.current = "settings"

            Button:
                text: "⟳"
                font_size: "24sp"
                size_hint_x: None
                width: "50dp"
                background_color: 0, 0, 0, 0
                on_release: root.refresh()

        # Content
        ScrollView:
            size_hint_y: 1

            GridLayout:
                id: items_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                padding: 10
                spacing: 10

        # Loading overlay
        BoxLayout:
            opacity: 1 if root.is_loading else 0
            disabled: not root.is_loading
            size_hint_y: 1
            canvas.before:
                Color:
                    rgb: 0.15, 0.18, 0.22
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "Loading..."
                font_size: "16sp"
                color: 0.7, 0.7, 0.7, 1

        # Error message
        Label:
            opacity: 1 if root.error_message else 0
            text: root.error_message
            font_size: "14sp"
            color: 0.9, 0.3, 0.3, 1
            size_hint_y: None
            height: "40dp"
            pos_hint: {"center_x": 0.5, "y": 0.3}
