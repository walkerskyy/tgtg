<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 50
        spacing: 20

        canvas.before:
            Color:
                rgb: 0.15, 0.18, 0.22
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "TGTG Scanner"
            font_size: "28sp"
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: "50dp"

        Label:
            text: "Monitor magic bags on your phone"
            font_size: "14sp"
            color: 0.7, 0.7, 0.7, 1
            size_hint_y: None
            height: "30dp"

        TextInput:
            id: email_input
            hint_text: "Your TGTG email"
            multiline: False
            keyboard_suggestions: True
            input_type: "email"
            size_hint_y: None
            height: "50dp"
            font_size: "16sp"
            valign: "middle"
            padding: [15, 0]
            background_color: 0.2, 0.22, 0.26, 1
            foreground_color: 1, 1, 1, 1
            cursor_color: 1, 1, 1, 1

        Button:
            text: "Send PIN"
            on_release: root.request_login(email_input.text)
            disabled: root.is_loading
            background_color: 0.29, 0.76, 0.26, 1
            font_size: "16sp"
            bold: True
            size_hint_y: None
            height: "50dp"

        TextInput:
            id: pin_input
            hint_text: "Enter 6-digit PIN"
            multiline: False
            input_type: "number"
            password: True
            size_hint_y: None
            height: "50dp"
            font_size: "20sp"
            valign: "middle"
            padding: [15, 0]
            background_color: 0.2, 0.22, 0.26, 1
            foreground_color: 1, 1, 1, 1
            cursor_color: 1, 1, 1, 1

        Button:
            text: "Verify PIN"
            on_release: root.submit_pin(pin_input.text)
            disabled: root.is_loading
            background_color: 0.29, 0.76, 0.26, 1
            font_size: "16sp"
            bold: True
            size_hint_y: None
            height: "50dp"

        ActivityIndicator:
            active: root.is_loading
            size_hint_y: None
            height: "30dp"

        Label:
            text: root.status_message
            font_size: "14sp"
            color: 1, 0.5, 0.5, 1 if "error" in root.status_message.lower() else 0.7, 0.7, 0.7, 1
            size_hint_y: None
            height: "40dp"
            text_size: self.width, None
            halign: "center"
